# ── FRYBIRD Admin credentials ──────────────────────────────
# Copy this file to ".env.local" and change every value before deploying.

# PostgreSQL connection string (Neon, Supabase, etc.)
# DATABASE_URL = pooled endpoint (used at runtime). On Neon this host contains "-pooler".
DATABASE_URL=postgresql://user:password@host-pooler/dbname?sslmode=require
# DIRECT_URL = direct (non-pooled) endpoint (used by `prisma migrate` / `db push`).
DIRECT_URL=postgresql://user:password@host/dbname?sslmode=require

# Login for /admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=frybird123

# Secret value stored in the session cookie. Use a long random string.
# e.g. run:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_TOKEN=change-me-to-a-long-random-string

# UploadThing token (image uploads + media library).
# Get it from https://uploadthing.com/dashboard → API Keys.
UPLOADTHING_TOKEN=your-uploadthing-token
